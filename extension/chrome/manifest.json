{
  "manifest_version": 3,
  "name": "Universal Download Manager",
  "version": "0.1.0",
  "description": "Intercept browser downloads and hand them to the UDM daemon for acceleration and resume.",
  "permissions": [
    "downloads",
    "webRequest",
    "cookies",
    "storage",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
