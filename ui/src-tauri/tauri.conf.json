{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UDM",
  "version": "0.1.0",
  "identifier": "com.udm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Universal Download Manager",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBMzgyMDhGRTZFNTMyNDQKUldSRU11WG1qeUE0NnVQZUZ2MnorM2JoVXpTYWdHNC9idndwWWQ3dWp4WUpDWGhEb1NuSFEvelYK",
      "endpoints": [
        "https://example.com/udm/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/udm-daemon"],
    "publisher": "UDM Team",
    "category": "Utility",
    "copyright": "© UDM Team",
    "shortDescription": "Universal Download Manager",
    "longDescription": "A fast, multi-segment download manager with browser integration, priority queueing, scheduling, and bandwidth control.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
